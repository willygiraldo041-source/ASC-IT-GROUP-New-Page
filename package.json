{
  "name": "asc-it-group-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter frontend --filter studio dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:studio": "pnpm --filter studio dev",
    "build": "pnpm --filter frontend build",
    "build:studio": "pnpm --filter studio build",
    "deploy": "pnpm --filter frontend deploy",
    "deploy:studio": "pnpm --filter studio deploy"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
